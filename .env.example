# Server-side only — set this in Vercel dashboard, NOT prefixed with VITE_
# For local dev, use `vercel dev` (not `vite`) so the /api function can read it
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Client-side (safe to expose — public keys only)
VITE_FOURSQUARE_API_KEY=your-foursquare-api-key-here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here
